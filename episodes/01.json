        {
          "ja": "ようこそ しろくまカフェへ",
          "en": "Welcome to Shirokuma Café."
        }
      ]
    },
    {
      "audio": 33,
      "lines": [
        {
          "ja": "お客様 お一人様ですか",
          "en": "Are you dining alone, sir/madam?"
