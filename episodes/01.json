      ]
    },
    {
      "audio": 54,
      "lines": [
        {
          "ja": "はい",
          "en": "Yes"
        },
        {
          "ja": "穴熊です",
          "en": "I'm Anaguma."
        },
        {
          "ja": "えーと ホール係やれますか",
          "en": "Uh, can you work as a hall attendant?"
        }
      ]
    },
    {
      "audio": 55,
      "lines": [
        {
          "ja": "はい ホールなら任せてください",
          "en": "Yes, you can count on me for the hall duties."
        },
        {
          "ja": "穴を掘るの 得意なんです",
          "en": "I'm good at digging holes."
        }
      ]
    },
    {
      "audio": 56,
      "lines": [
        {
          "ja": "いや そのホールは違うし",
          "en": "No, that's not the right kind of hole."
        }
      ]
    },
    {
      "audio": 57,
      "lines": [
        {
          "ja": "次の方",
          "en": "Next person, please."
        },
        {
          "ja": "はい",
          "en": "Yes"
        },
        {
          "ja": "ゾ～ウ～ガ～メ～で～す",
          "en": "I am a giant tortoise."
