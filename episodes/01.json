      ]
    },
    {
      "audio": 63,
      "lines": [
        {
          "ja": "ちょっと それは",
          "en": "Wait, hold on a second."
        }
      ]
    },
    {
      "audio": 64,
      "lines": [
        {
          "ja": "小蟻食です",
          "en": "I specialize in eating ants."
        },
        {
          "ja": "い 威嚇ができます",
          "en": "I can intimidate."
        }
      ]
    },
    {
      "audio": 65,
      "lines": [
        {
          "ja": "それだけ",
          "en": "That's all."
        },
        {
          "ja": "みたいだね",
          "en": "Seems like it."
        }
      ]
    },
    {
      "audio": 66,
      "lines": [
        {
          "ja": "最後の方 どうぞ",
          "en": "Please, go ahead with the last part."
        },
        {
          "ja": "はい",
          "en": "Yes"
        },
        {
          "ja": "パンダと申します",
          "en": "My name is Panda."
        },
        {
          "ja": "よろしくです",
          "en": "Nice to meet you."
        }
      ]
    },
    {
      "audio": 67,
      "lines": [
        {
          "ja": "やっとまともな人が来たね",
          "en": "Finally, a decent person has come."
        }
      ]
    },
    {
      "audio": 68,
      "lines": [
        {
          "ja": "パンダ君 何か得意なことはありますか",
          "en": "Panda-kun, is there anything you're particularly good at?"
        },
        {
          "ja": "はい ゴロゴロしながら笹を食べることです",
          "en": "Yes, it's eating bamboo while lounging around."
        }
      ]
    },
    {
      "audio": 69,
      "lines": [
        {
          "ja": "あれ",
          "en": "Oh."
        },
        {
          "ja": "えーと 条件に希望はありますか",
          "en": "Um, do you have any preferences regarding the conditions?"
        }
      ]
    },
    {
      "audio": 70,
      "lines": [
        {
          "ja": "週二日希望です",
          "en": "I hope for two days a week."
        },
        {
          "ja": "うん 週二日ですか",
          "en": "Hmm, two days a week, huh?"
        }
      ]
    },
    {
      "audio": 71,
      "lines": [
        {
          "ja": "え 週一日でいいんですか",
          "en": "Huh, is one day a week okay?"
        },
        {
          "ja": "いや せめて週四日くらい",
          "en": "No, at least around four days a week."
        }
      ]
    },
    {
      "audio": 72,
      "lines": [
        {
          "ja": "そんなの無理です",
          "en": "That's impossible."
        }
      ]
    },
    {
      "audio": 73,
      "lines": [
        {
          "ja": "あ けど",
          "en": "Ah, but..."
        },
        {
          "ja": "呼びに来てくれたら すぐ行きます",
          "en": "If you come to get me, I'll go right away."
        }
      ]
    },
    {
      "audio": 74,
      "lines": [
        {
          "ja": "僕が呼びに行くんですか",
          "en": "Am I the one who has to go and call you?"
        },
        {
          "ja": "あ そんなそんな",
          "en": "Oh, no, no, that's not necessary."
        },
        {
          "ja": "遅刻した場合だけですよ",
          "en": "Only if I'm late."
        }
      ]
    },
    {
      "audio": 75,
      "lines": [
        {
          "ja": "遅刻する気満々だね",
          "en": "You're totally planning on being late, aren't you?"
        }
      ]
    },
    {
      "audio": 76,
      "lines": [
        {
          "ja": "ちなみに やる気はありますか",
          "en": "By the way, are you motivated?"
        },
        {
          "ja": "そんなにありません",
          "en": "Not really."
        }
      ]
    },
    {
      "audio": 77,
      "lines": [
        {
          "ja": "発表します",
          "en": "I'll make an announcement."
        },
        {
          "ja": "全員不合格",
          "en": "Everyone failed."
        }
      ]
    },
    {
      "audio": 78,
      "lines": [
        {
          "ja": "えー工",
          "en": "Ugh, seriously?"
        },
        {
          "ja": "そこ驚くとこ",
          "en": "That's the surprising part."
        }
      ]
    },
    {
      "audio": 79,
      "lines": [
        {
          "ja": "結局バイトの人",
          "en": "In the end, it's the part-timer."
        },
        {
          "ja": "見つからなかったね",
          "en": "Couldn't find them, huh?"
        }
      ]
    },
    {
      "audio": 80,
      "lines": [
        {
          "ja": "残念だね",
          "en": "That's unfortunate."
        },
        {
          "ja": "まだいたの",
          "en": "You're still here?"
        },
        {
          "ja": "家に帰ると お母さんに吸われるし",
          "en": "When I get home, my mom will nag me."
        },
        {
          "ja": "す 吸われる",
          "en": "G-Get sucked?"
        }
      ]
    },
    {
      "audio": 81,
      "lines": [
        {
          "ja": "うん　ゴーって",
          "en": "Yeah, like \"whoosh.\""
        },
        {
          "ja": "あのう　面接中すみません",
          "en": "Um, sorry to interrupt during the interview."
        }
      ]
    },
    {
      "audio": 82,
      "lines": [
        {
          "ja": "住み込み希望でーす",
          "en": "I’d like to live in, please."
        },
        {
          "ja": "不合格",
          "en": "Rejected"
        }
      ]
    },
    {
      "audio": 83,
      "lines": [
