    },
    {
      "audio": 58,
      "lines": [
        {
          "ja": "料理とか 運べますか",
          "en": "Can you carry food and such?"
        },
        {
          "ja": "は～い～",
          "en": "Yes, I can."
        }
      ]
    },
    {
      "audio": 59,
      "lines": [
        {
          "ja": "ヨ～イ～ショー",
          "en": "Heave-ho!"
        },
        {
          "ja": "ゆっくりだね",
          "en": "You're slow, aren't you?"
        },
        {
          "ja": "うん",
          "en": "Yeah."
        },
        {
          "ja": "百年くらい働かせて～",
          "en": "Let me work for about a hundred years~"
        }
      ]
    },
    {
      "audio": 60,
      "lines": [
        {
          "ja": "いえ そんなには",
          "en": "Oh, not that long."
        }
      ]
    },
    {
      "audio": 61,
      "lines": [
        {
          "ja": "マンドリルです",
          "en": "It's a mandrill."
        }
      ]
    },
    {
      "audio": 62,
      "lines": [
        {
          "ja": "食べるのが得意です",
          "en": "I'm good at eating."
