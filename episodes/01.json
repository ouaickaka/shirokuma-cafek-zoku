      ]
    },
    {
      "audio": 34,
      "lines": [
        {
          "ja": "あ 別に僕は",
          "en": "Oh, I'm not really..."
        }
      ]
    },
    {
      "audio": 35,
      "lines": [
        {
          "ja": "お好きな席へどうぞ",
          "en": "Please feel free to sit wherever you like."
        }
      ]
    },
    {
      "audio": 36,
      "lines": [
        {
          "ja": "ご注文は",
          "en": "What would you like to order?"
        },
        {
          "ja": "えーと 竹はありますか",
          "en": "Um, do you have bamboo?"
        }
      ]
    },
    {
      "audio": 37,
      "lines": [
        {
          "ja": "竹はないです",
          "en": "We don't have bamboo."
        }
      ]
    },
    {
      "audio": 38,
      "lines": [
        {
          "ja": "じゃ 笹ください",
          "en": "Then, I'll have sasa, please."
        },
        {
          "ja": "笹もないです",
          "en": "We don't have sasa either."
        },
        {
          "ja": "じゃ アイスコーヒー",
          "en": "Then, I'll have an iced coffee."
        },
        {
          "ja": "はい",
          "en": "Yes"
        }
      ]
    },
    {
      "audio": 39,
      "lines": [
        {
          "ja": "ねえ 白熊くん",
          "en": "Hey, Polar Bear."
        },
        {
          "ja": "財布のポイントカードって増えすぎちゃわな",
          "en": "Don't you think the point cards in your wallet just keep piling up?"
        }
      ]
    },
    {
      "audio": 40,
      "lines": [
        {
          "ja": "ペンギンさん ポイント貯める派",
          "en": "Penguin, are you the type who likes to collect points?"
        },
        {
          "ja": "うん",
          "en": "Yeah."
        },
        {
          "ja": "あ カフェモカお願い おかわり",
          "en": "Oh, can I have a café mocha, please? A refill."
        }
      ]
    },
    {
      "audio": 41,
      "lines": [
        {
          "ja": "それはひまわり",
          "en": "That's a sunflower."
        }
      ]
    },
    {
      "audio": 42,
      "lines": [
        {
          "ja": "それは日替わり",
          "en": "That's the daily special."
        }
      ]
    },
    {
      "audio": 43,
      "lines": [
        {
          "ja": "それは薪割り",
          "en": "That's firewood chopping."
        }
      ]
    },
    {
      "audio": 44,
      "lines": [
        {
          "ja": "それは西瓜割り",
          "en": "That's watermelon splitting."
        },
        {
          "ja": "「おかわり」ね",
          "en": "\"Refill,\" right?"
        }
      ]
    },
    {
      "audio": 45,
      "lines": [
        {
          "ja": "はい カフェモカ",
          "en": "Here you go, a café mocha."
        },
        {
          "ja": "このカフェ ダジャレがなければなぁ",
          "en": "I wish this café didn't have puns."
        }
      ]
    },
    {
      "audio": 46,
      "lines": [
        {
          "ja": "そういえば アルバイト募集してるんだって",
          "en": "Speaking of which, I heard they're hiring part-timers."
