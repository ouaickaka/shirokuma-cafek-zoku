      ]
    },
    {
      "audio": 9,
      "lines": [
        {
          "ja": "続きまして 私と同じ職場に勤める",
          "en": "Next, someone who works at the same place as me."
        }
      ]
    },
    {
      "audio": 10,
      "lines": [
        {
          "ja": "パンダくんを紹介します！",
          "en": "Let me introduce Panda-kun!"
        },
        {
          "ja": "だから　かたいって…",
          "en": "That's why you're being too formal..."
        },
        {
          "ja": "すみません パンダ　連れてきちゃって",
          "en": "Sorry for bringing Panda along."
        }
      ]
    },
    {
      "audio": 11,
      "lines": [
        {
          "ja": "パンダで～す",
          "en": "I'm Panda!"
        },
        {
          "ja": "かわいい！！",
          "en": "So cute!!"
        },
        {
          "ja": "パンダ　意外にウケた…",
          "en": "The panda was surprisingly well-received..."
        },
        {
          "ja": "では　続いて…",
          "en": "Now, moving on..."
        }
      ]
    },
    {
      "audio": 12,
      "lines": [
        {
          "ja": "シロクマです ふだんは　カフェやってます",
          "en": "I'm a polar bear. I usually run a café."
        },
        {
          "ja": "すご～い！",
          "en": "Amazing!"
        },
        {
          "ja": "カフェですか？",
          "en": "A café?"
        }
      ]
    },
    {
      "audio": 13,
      "lines": [
        {
          "ja": "行ってみたい！",
          "en": "I want to go!"
        },
        {
          "ja": "なんてカフェですか？",
          "en": "What's the name of the café?"
        },
        {
          "ja": "しろくまカフェ",
          "en": "Polar Bear Café"
