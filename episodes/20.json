      ]
    },
    {
      "audio": 18,
      "lines": [
        {
          "ja": "じゃあ　女子 いきますね",
          "en": "Alright, let's move on to the girls."
        },
        {
          "ja": "ヒロミで～す",
          "en": "I'm Hiromi!"
        },
        {
          "ja": "先輩　ヒロミちゃん",
          "en": "Senpai, Hiromi-chan."
