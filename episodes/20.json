{
  "ep": "20",
  "title": "半田さんの合コン！",
  "scenes": [
    {
      "audio": 0,
      "lines": [
        {
          "ja": "前半からつづく",
          "en": "Continued from the first half"
        }
      ]
    },
    {
      "audio": 1,
      "lines": [
        {
          "ja": "ご注文　お決まりですか？",
          "en": "Are you ready to order?"
        }
      ]
    },
    {
      "audio": 2,
      "lines": [
        {
          "ja": "シロクマ！？",
          "en": "Polar bear!?"
