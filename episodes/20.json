      ]
    },
    {
      "audio": 17,
      "lines": [
        {
          "ja": "何ですか？それ",
          "en": "What is that?"
        },
        {
          "ja": "今度連れてってください",
          "en": "Please take me with you next time."
        },
        {
          "ja": "やめたほうがいいよ…",
          "en": "You'd better not..."
