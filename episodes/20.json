      ]
    },
    {
      "audio": 8,
      "lines": [
        {
          "ja": "大丈夫です",
          "en": "It's all right."
        },
        {
          "ja": "合コンって　そういう感じのものじゃないんで",
          "en": "A group date isn't really something like that."
