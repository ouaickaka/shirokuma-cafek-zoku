      ]
    },
    {
      "audio": 3,
      "lines": [
        {
          "ja": "そ…　それじゃ 自己紹介から始めましょうか",
          "en": "W-Well then, shall we start with introductions?"
        }
      ]
    },
    {
      "audio": 4,
      "lines": [
        {
          "ja": "僕からいきますね",
          "en": "I'll go first."
        },
        {
          "ja": "桐野です",
          "en": "I'm Kirino."
        },
        {
          "ja": "動物園の飼育員をやっています",
          "en": "I work as a zookeeper."
        }
      ]
    },
    {
      "audio": 5,
      "lines": [
        {
          "ja": "じゃ　次は先輩",
          "en": "Okay, next is you, Senpai."
        },
        {
          "ja": "は…　は…　半田です！",
          "en": "I- I- I'm Handa!"
        },
        {
          "ja": "本日は　このように 晴れがましい合コンに　お…　お招きいただき",
          "en": "Today, I am honored to be invited to such a splendid mixer..."
        }
      ]
    },
    {
      "audio": 6,
      "lines": [
        {
          "ja": "誠にありがとうございます",
          "en": "I sincerely thank you."
        },
        {
          "ja": "ふつつか者ではありますが",
          "en": "I may be inexperienced, but..."
        },
        {
          "ja": "以後　よろしく お見知りおきください",
          "en": "I look forward to getting to know you better from now on."
        }
      ]
    },
    {
      "audio": 7,
      "lines": [
        {
          "ja": "先輩　かたい…",
          "en": "Senpai, you're so stiff..."
        },
        {
          "ja": "そこまで丁寧な 自己紹介じゃなくて大丈夫です",
          "en": "You don't need to introduce yourself so formally."
        },
        {
          "ja": "けど　初対面だから",
          "en": "But it's our first meeting."
