      ]
    },
    {
      "audio": 16,
      "lines": [
        {
          "ja": "こっちも大好評だな…",
          "en": "This is really popular here too..."
        },
        {
          "ja": "趣味は　アザラシの捕獲",
          "en": "My hobby is capturing seals."
