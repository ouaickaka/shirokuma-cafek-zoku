        {
          "ja": "それは　井戸端",
          "en": "That's a water cooler chat."
        },
        {
          "ja": "それは　花畑",
          "en": "That's a flower field."
        },
        {
          "ja": "七夕はね",
          "en": "Tanabata is..."
