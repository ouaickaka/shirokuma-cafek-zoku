        {
          "ja": "ちょっと味見",
          "en": "A little taste."
        }
      ]
    },
    {
      "audio": 1,
      "lines": [
        {
          "ja": "おいしい！",
          "en": "Delicious!"
        },
        {
          "ja": "まったく　もう…",
          "en": "Honestly, really..."
        },
        {
          "ja": "もったいないな",
          "en": "What a waste."
        },
        {
          "ja": "おいしい！",
          "en": "Delicious!"
        },
        {
          "ja": "あっ",
          "en": "Ah!"
        }
      ]
    },
    {
      "audio": 2,
      "lines": [
        {
          "ja": "パンダくん",
