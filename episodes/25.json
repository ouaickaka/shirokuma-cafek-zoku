{
  "ep": "25",
  "title": "七夕飾り",
  "scenes": [
    {
      "audio": 0,
      "lines": [
        {
          "ja": "あれ？",
          "en": "Huh?"
        },
        {
          "ja": "あんなところにおいしそうな笹が落ちてる",
          "en": "There's some delicious-looking bamboo grass fallen over there."
