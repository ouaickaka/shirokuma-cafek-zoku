        {
          "ja": "笹パーティー？",
          "en": "Bamboo party?"
        },
        {
          "ja": "笹だらけのパーティーだよ",
          "en": "It's a party full of bamboo!"
        }
      ]
    },
    {
      "audio": 3,
      "lines": [
        {
          "ja": "七夕飾りに使うんだよ",
          "en": "We're going to use it for Tanabata decorations."
